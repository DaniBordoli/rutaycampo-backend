{
  "name": "rutaycampo-backend",
  "version": "1.0.0",
  "description": "Backend API para Ruta y Campo - Sistema de orquestación de viajes",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "set:dev": "node -e \"require('fs').copyFileSync('.env.staging', '.env'); console.log('✅ .env <- .env.staging')\"",
    "set:prod": "node -e \"require('fs').copyFileSync('.env.production', '.env'); console.log('✅ .env <- .env.production')\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "logistics",
    "transport",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "socket.io": "^4.6.1",
    "twilio": "^4.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
